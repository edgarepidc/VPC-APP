generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id          String       @id @default(uuid())
  name        String
  slug        String       @unique
  /** Logo del workspace (URL pública, p. ej. Supabase Storage). */
  logoUrl     String?
  plan        String       @default("starter")
  memberships Membership[]
  invitations Invitation[]
  roles       Role[]
  projects    Project[]
  deliverables Deliverable[]
  risks       Risk[]
  stakeholders Stakeholder[]
  tasks       Task[]
  escalationChecks EscalationCheck[]
  meetingRoiSessions MeetingRoiSession[]
  meetingMinutes     MeetingMinute[]
  createdAt   DateTime     @default(now())
}

model User {
  id          String       @id @default(uuid())
  email       String       @unique
  name        String?
  /** Teléfono de contacto (gestión plataforma / perfil). */
  phone       String?
  jobTitle    String?
  department  String?
  /** Último inicio de sesión (sincronizado desde Supabase Auth). */
  lastSignInAt DateTime?
  passwordHash String?
  isActive    Boolean      @default(true)
  /** Plataforma: gestiona tenants y usuarios globales (ademas de env PLATFORM_SUPERADMIN_EMAILS). */
  isSuperAdmin Boolean     @default(false)
  /** Foto de perfil (URL pública, p. ej. Supabase Storage). */
  avatarUrl   String?
  memberships Membership[]
  sentInvitations Invitation[] @relation("InvitationSender")
  assignedTasks Task[]
  auditLogs   UserAuditLog[] @relation("AuditTarget")
  performedAudits UserAuditLog[] @relation("AuditActor")
  createdAt   DateTime     @default(now())
}

model UserAuditLog {
  id          String   @id @default(uuid())
  userId      String
  actorUserId String?
  action      String
  details     String?
  createdAt   DateTime @default(now())
  user        User     @relation("AuditTarget", fields: [userId], references: [id], onDelete: Cascade)
  actor       User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([createdAt])
}

model Membership {
  id                 String              @id @default(uuid())
  tenantId           String
  userId             String
  roleId             String
  status             String              @default("active")
  /** PM (manager): true = todos los proyectos del tenant. */
  managerAllProjects Boolean             @default(false)
  /** PM (manager): true = solo lectura en entregables, riesgos, escalómetro, etc. */
  managerReadOnly    Boolean             @default(false)
  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  role               Role                @relation(fields: [roleId], references: [id])
  projectAccess      MembershipProject[]

  @@unique([tenantId, userId])
}

model MembershipProject {
  membershipId String
  projectId    String
  membership   Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([membershipId, projectId])
  @@index([projectId])
}

model Role {
  id              String           @id @default(uuid())
  tenantId        String
  key             String
  name            String
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberships     Membership[]
  rolePermissions RolePermission[]

  @@unique([tenantId, key])
}

model Permission {
  id              String           @id @default(uuid())
  key             String           @unique
  description     String?
  rolePermissions RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Project {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  description String?
  status      String   @default("active")
  createdBy   String
  /** null = iniciativa (contenedor); con valor = subproyecto de trabajo. */
  parentProjectId String?
  sortOrder   Int      @default(0)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parentProject Project?  @relation("ProjectHierarchy", fields: [parentProjectId], references: [id], onDelete: Cascade)
  subProjects   Project[] @relation("ProjectHierarchy")
  deliverables Deliverable[]
  risks       Risk[]
  stakeholders Stakeholder[]
  tasks       Task[]
  escalationChecks EscalationCheck[]
  meetingRoiSessions MeetingRoiSession[]
  meetingMinutes     MeetingMinute[]
  membershipAccess MembershipProject[]
  invitationAccess InvitationProject[]
  createdAt   DateTime @default(now())

  @@index([tenantId, parentProjectId])
}

model Task {
  id             String   @id @default(uuid())
  tenantId       String
  projectId      String
  title          String
  status         String   @default("todo")
  assigneeUserId String?
  dueDate        DateTime?
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee       User?    @relation(fields: [assigneeUserId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())
}

model Invitation {
  id                 String              @id @default(uuid())
  tenantId           String
  email              String
  roleKey            String
  status             String              @default("pending")
  invitedBy          String
  managerAllProjects Boolean             @default(false)
  managerReadOnly    Boolean             @default(false)
  acceptedAt         DateTime?
  createdAt          DateTime            @default(now())
  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sender             User                @relation("InvitationSender", fields: [invitedBy], references: [id], onDelete: Cascade)
  projectAccess      InvitationProject[]

  @@index([tenantId, email, status])
}

model InvitationProject {
  invitationId String
  projectId    String
  invitation   Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([invitationId, projectId])
}

model Deliverable {
  id                  String    @id @default(uuid())
  tenantId            String
  projectId           String
  title               String
  /** Fase del proyecto (p. ej. Diseño, QA). */
  cell                String?
  ownerName           String?
  /** Cliente o área destinataria del entregable. */
  clientName          String?
  status              String    @default("pending")
  dueDate             DateTime?
  /** Porcentaje de participación en el avance del proyecto (1–100; suma 100 por proyecto). */
  weight              Int       @default(100)
  /** true = el usuario fijó el % manualmente; no se auto-ajusta al editar otros. */
  weightManual        Boolean   @default(false)
  description         String?
  acceptanceCriteria  String?
  notes               String?
  /** Enlace a carpeta o ubicación del entregable (SharePoint, Drive, etc.). */
  supportUrl          String?
  /** URL pública del PDF de soporte en storage. */
  supportFileUrl      String?
  supportFileName     String?
  /** PDFs adjuntos: [{ "url", "name", "uploadedAt" }]. */
  supportFiles        Json      @default("[]")
  /** Fecha real de cierre (aprobado / entregado). */
  deliveredAt         DateTime?
  /** Entregable predecesor que debe completarse antes. */
  dependsOnId         String?
  dependsOn           Deliverable?  @relation("DeliverableDependency", fields: [dependsOnId], references: [id], onDelete: SetNull)
  dependents          Deliverable[] @relation("DeliverableDependency")
  /** Lista de acuses: [{ "name", "role", "ok", "confirmedAt" }]. */
  acuses              Json      @default("[]")
  /** Historial: [{ "at", "text", "color?" }]. */
  activityLog         Json      @default("[]")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  tenant              Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project             Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  risks               Risk[]

  @@index([tenantId, projectId, status])
}

model Risk {
  id             String      @id @default(uuid())
  tenantId       String
  projectId      String
  deliverableId  String?
  title          String
  category       String      @default("Tecnico")
  ownerName      String
  probability    Int
  residualProb   Int
  impactAmount   Float
  status         String      @default("open")
  mitigation     String?
  contingency    String?
  trigger        String?
  dueDate        DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project        Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deliverable    Deliverable? @relation(fields: [deliverableId], references: [id], onDelete: SetNull)

  @@index([tenantId, projectId, status])
}

model Stakeholder {
  id           String   @id @default(uuid())
  tenantId     String
  projectId    String
  name         String
  role         String?
  influence    Int
  interest     Int
  observation  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([tenantId, projectId])
}

/** Evaluación ligera del Escalómetro — distinta al registro formal de riesgos. */
model EscalationCheck {
  id          String   @id @default(uuid())
  tenantId    String
  projectId   String
  /** Subproyecto, tema o situación evaluada (opcional). */
  topic       String?
  /** green | orange | red */
  tier        String
  title       String
  levelLabel  String
  /** Mapa de indicador → low | medium | high */
  indicators  Json
  /** Acciones recomendadas generadas */
  actions     Json
  createdBy   String
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([tenantId, projectId, createdAt])
  @@index([tenantId, createdAt])
}

model MeetingRoiSession {
  id                String   @id @default(uuid())
  tenantId          String
  projectId         String
  /** Nombre de la sesión o reunión (opcional). */
  sessionName       String?
  /** informativa | decision | tecnica | crisis */
  objective         String
  totalCost         Float
  /** Bajo | Moderado | Alto | Crítico */
  costLevel         String
  costPerMinute     Float
  totalParticipants Int
  durationMinutes   Int
  diagnosisTitle    String
  diagnosisText     String
  /** Conteo por rol: junior, senior, director, tech */
  participants      Json
  /** Costo por rol en MXN */
  roleCosts         Json
  createdBy         String
  createdAt         DateTime @default(now())
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([tenantId, projectId, createdAt])
  @@index([tenantId, createdAt])
}

model MeetingMinute {
  id          String    @id @default(uuid())
  tenantId    String
  projectId   String
  title       String
  meetingDate DateTime?
  /** Resumen, puntos tratados y acuerdos (sin transcripción). */
  content     Json
  provider    String
  model       String
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([tenantId, projectId, createdAt])
  @@index([tenantId, createdAt])
}
